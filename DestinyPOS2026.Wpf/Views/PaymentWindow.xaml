<Window x:Class="DestinyPOS2026.Wpf.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Transaction" Height="360" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Confirm Transaction" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" />

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Amount Due:" Width="120" VerticalAlignment="Center" />
                <TextBlock Text="{Binding AmountDue, StringFormat=₱{0:N2}}" VerticalAlignment="Center" FontWeight="Bold" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Payment Method:" Width="120" VerticalAlignment="Center" />
                <ComboBox Width="200" SelectedValue="{Binding PaymentMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content">
                    <ComboBoxItem Content="CASH" />
                    <ComboBoxItem Content="GCASH" />
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Vertical" Visibility="{Binding GcashQrVisibility}" Margin="0,10,0,8">
                <TextBlock Text="Scan to pay:" FontSize="12" Margin="0,0,0,6" />
                <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="8" HorizontalAlignment="Left">
                    <Image Source="{Binding GcashQrImage}" Width="140" Height="140" Stretch="Uniform" />
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Cash Tendered:" Width="120" VerticalAlignment="Center" />
                <TextBox Width="200" Text="{Binding CashTendered, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Background="#F8F8F8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Change Due:" Width="120" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ChangeDue, StringFormat=₱{0:N2}}" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status:" Width="120" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding PaymentStatus}" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Text="Enter cash tendered only for CASH payments. For GCash, scan the QR code above." TextWrapping="Wrap" Foreground="#666" Margin="0,10,0,0" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Height="36" Margin="0,0,10,0" Click="Cancel_Click" />
            <Button Content="Complete Sale" Width="130" Height="36" Background="#4CAF50" Foreground="White" Click="Complete_Click" />
        </StackPanel>
    </Grid>
</Window>
