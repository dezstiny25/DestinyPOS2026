<UserControl x:Class="DestinyPOS2026.Wpf.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DestinyPOS2026.Wpf.ViewModels"
             xmlns:local="clr-namespace:DestinyPOS2026.Wpf.Views"
             Height="700" Width="1000">

    <UserControl.DataContext>
        <vm:PosViewModel />
    </UserControl.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*" MinWidth="480" />
            <ColumnDefinition Width="1*" MinWidth="220" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Search Products" FontWeight="Bold" Margin="0,0,0,5" Foreground="#333" />

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <local:SearchItemsControl x:Name="SearchControl"
                                      Grid.Column="0"
                                      ItemSelected="SearchItemsControl_ItemSelected"
                                      SearchText="{Binding BarcodeInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SearchRequested="SearchItemsControl_SearchRequested" />

            <Button Grid.Column="1"
                    Content="Add Item"
                    Width="120"
                    Height="35"
                    Margin="10,0,0,0"
                    Background="#1976D2"
                    Foreground="White"
                    FontWeight="Bold"
                    Command="{Binding AddItemCommand}" />
        </Grid>

        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Add Service"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="#FF9800"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding AddServiceCommand}" />

                <Button Content="Add Item"
                        Width="110"
                        Height="35"
                        Margin="0,0,0,0"
                        Background="#1976D2"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding AddItemCommand}" />
            </StackPanel>

            <TextBlock Text="Transaction Items" FontWeight="Bold" Margin="0,0,0,5" Foreground="#333" />
            <Border BorderThickness="1" BorderBrush="#CCCCCC" Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                    <DataGrid ItemsSource="{Binding SaleItems}"
                              AutoGenerateColumns="False"
                              BorderThickness="0"
                              Background="White"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding ItemType}" Width="80" />
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=₱{0:N2}}" Width="90" />
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=₱{0:N2}}" Width="90" />
                            <DataGridTemplateColumn Header="Action" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove"
                                                Height="25"
                                                Padding="5"
                                                Background="#F44336"
                                                Foreground="White"
                                                FontSize="11"
                                                Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding .}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <Border Grid.Row="3" Grid.Column="0" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#CCCCCC" Background="#F5F5F5" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                    <TextBlock Text="Subtotal: " FontWeight="Bold" Width="110" />
                    <TextBlock Text="{Binding Subtotal, StringFormat=₱{0:N2}}" Width="110" TextAlignment="Right" />
                </StackPanel>
                <Separator Margin="0,5,0,5" Background="#CCCCCC" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="TOTAL: " FontWeight="Bold" FontSize="14" Width="110" />
                    <TextBlock Text="{Binding Total, StringFormat=₱{0:N2}}"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="#2196F3"
                               Width="110"
                               TextAlignment="Right" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Grid.Column="0" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#CCCCCC" Background="#FAFAFA" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                    <TextBlock Text="Payment Method:" FontWeight="Bold" Width="140" />
                    <TextBlock Text="{Binding CurrentPaymentMethod}" Width="140" TextAlignment="Right" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                    <TextBlock Text="Cash Tendered:" FontWeight="Bold" Width="140" />
                    <TextBlock Text="{Binding CashTendered, StringFormat=₱{0:N2}}" Width="140" TextAlignment="Right" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                    <TextBlock Text="Change Due:" FontWeight="Bold" Width="140" />
                    <TextBlock Text="{Binding ChangeDue, StringFormat=₱{0:N2}}" Width="140" TextAlignment="Right" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Payment Status:" FontWeight="Bold" Width="140" />
                    <TextBlock Text="{Binding PaymentStatus}" Width="140" TextAlignment="Right" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
            <Button Content="Confirm Transaction"
                    Width="170"
                    Height="45"
                    Margin="5"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="13"
                    Command="{Binding ConfirmSaleCommand}" />

            <Button Content="Clear All"
                    Width="120"
                    Height="45"
                    Margin="5"
                    Background="#9C27B0"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="13"
                    Command="{Binding ClearAllCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.RowSpan="6" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20,0,0,0">
            <TextBlock Text="Scan QR Code with phone" FontWeight="Bold" Margin="0,0,0,10" TextAlignment="Center" />
            <Border BorderThickness="2" BorderBrush="#2196F3" CornerRadius="5" Padding="5">
                <Image Width="200" Height="200" Source="{Binding QrCodeImage}" />
            </Border>
            <TextBlock Text="Mobile Scanner" FontStyle="Italic" Foreground="#666666" Margin="0,10,0,0" TextAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
