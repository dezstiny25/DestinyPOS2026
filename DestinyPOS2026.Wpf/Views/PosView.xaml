<UserControl x:Class="DestinyPOS2026.Wpf.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DestinyPOS2026.Wpf.ViewModels"
             Height="600" Width="900">

    <UserControl.DataContext>
        <vm:PosViewModel />
    </UserControl.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- Left side: Sale Items -->
        <StackPanel Grid.Column="0">
            <TextBox Margin="0,0,0,10"
                     Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                     Width="250"
                     Height="30"
                     VerticalAlignment="Top"
                     ToolTip="Enter or scan barcode" />

            <DataGrid ItemsSource="{Binding SaleItems}" AutoGenerateColumns="False" Height="400">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="50" />
                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="100" />
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:N2}}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <TextBlock Text="Subtotal: " FontWeight="Bold" />
                <TextBlock Text="{Binding Subtotal, StringFormat=N2}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Discount: " FontWeight="Bold" />
                <TextBlock Text="{Binding Discount, StringFormat=N2}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Total: " FontWeight="Bold" />
                <TextBlock Text="{Binding Total, StringFormat=N2}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0" >
                <Button Content="Add Item" Width="80" Margin="5" Command="{Binding AddItemCommand}" />
                <Button Content="Cash" Width="80" Margin="5" Command="{Binding PayCashCommand}" />
                <Button Content="GCash" Width="80" Margin="5" Command="{Binding PayGcashCommand}" />
                <Button Content="Card" Width="80" Margin="5" Command="{Binding PayCardCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- Right side: QR Code for phone pairing -->
        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top">
            <TextBlock Text="Scan QR Code with phone" FontWeight="Bold" Margin="0,0,0,10" />
            <Image Width="250" Height="250" Source="{Binding QrCodeImage}" />
        </StackPanel>
    </Grid>
</UserControl>
