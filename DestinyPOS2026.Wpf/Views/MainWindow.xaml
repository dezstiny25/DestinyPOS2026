<Window
    x:Class="DestinyPOS2026.Wpf.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:DestinyPOS2026.Wpf.ViewModels"
    xmlns:views="clr-namespace:DestinyPOS2026.Wpf.Views"
    Title="DestinyPOS 2026"
    Height="700"
    Width="1200"
    WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Main content -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#1E1E1E">
            <Button Content="POS"
                    Command="{Binding ShowPosCommand}"
                    Margin="10"
                    Height="50"
                    Foreground="White"
                    Background="#252525"/>
            <Button Content="Inventory"
                    Command="{Binding ShowInventoryCommand}"
                    Margin="10"
                    Height="50"
                    Foreground="White"
                    Background="#252525"/>
            <Button Content="Reports"
                    Command="{Binding ShowReportsCommand}"
                    Margin="10"
                    Height="50"
                    Foreground="White"
                    Background="#252525"/>
        </StackPanel>

        <!-- Main Content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <views:DashboardView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:PosViewModel}">
                    <views:PosView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
                    <views:InventoryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                    <views:ReportsView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
        
        <!-- Status bar -->
        <StatusBar Grid.ColumnSpan="2" VerticalAlignment="Bottom">
            <TextBlock Text=""/>
            <TextBlock Text="Server: " FontWeight="Bold" Margin="8,0,0,0" />
            <TextBlock Text="{Binding ServerStatus}" />
        </StatusBar>
    </Grid>
</Window>
