<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <!-- Prevent duplicate assembly attributes generated by SDK/tooling in some environments -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Avoid auto-generation of TargetFrameworkAttribute when tooling also emits it -->
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.1" />
    <PackageReference Include="QRCoder" Version="1.7.0" />
    <PackageReference Include="EPPlus" Version="7.2.1" />
  </ItemGroup>

</Project>
